# ProEdge Analytics — environment configuration
# Copy this file to .env and fill in your values.
# Pydantic-settings reads .env automatically on startup.

# ── Database ──────────────────────────────────────────────────────────────────
# Credentials used by docker-compose for the Postgres container
POSTGRES_USER=proedge
POSTGRES_PASSWORD=proedge
POSTGRES_DB=proedge

DATABASE_URL=postgresql+asyncpg://proedge:proedge@localhost:5432/proedge
DATABASE_URL_SYNC=postgresql://proedge:proedge@localhost:5432/proedge

# ── API server ────────────────────────────────────────────────────────────────
API_HOST=0.0.0.0
API_PORT=8000
API_WORKERS=4
SECRET_KEY=change-me-in-production

# ── Auth ──────────────────────────────────────────────────────────────────────
# When set, all /predictions and /training requests require X-API-Key: <value>
# Leave empty to disable auth (fine for local dev).
API_KEY=

# ── Model Registry ────────────────────────────────────────────────────────────
MODEL_REGISTRY_PATH=./models
ACTIVE_MODEL_VERSION=latest

# ── The Odds API (https://the-odds-api.com) ───────────────────────────────────
# Free tier: 500 req/month. Leave empty to use caller-supplied total_line only.
ODDS_API_KEY=

# ── Alerts ────────────────────────────────────────────────────────────────────
# Minimum model confidence (0–1) that triggers a webhook alert
ALERT_CONFIDENCE_THRESHOLD=0.65
# Slack / Discord incoming webhook URL — leave empty to disable
ALERT_WEBHOOK_URL=

# ── Drift detection ───────────────────────────────────────────────────────────
# PSI >= threshold triggers an automated retrain (0.10=minor, 0.25=major)
DRIFT_PSI_THRESHOLD=0.25
DRIFT_CHECK_INTERVAL_HOURS=24

# ── Sports data APIs (optional enrichment) ────────────────────────────────────
SPORTRADAR_API_KEY=
ESPN_API_BASE_URL=https://site.api.espn.com/apis/site/v2/sports

# ── Azure ML (optional remote registry) ──────────────────────────────────────
AZURE_SUBSCRIPTION_ID=
AZURE_RESOURCE_GROUP=proedge-rg
AZURE_ML_WORKSPACE=proedge-ws
AZURE_TENANT_ID=
AZURE_CLIENT_ID=
AZURE_CLIENT_SECRET=

# ── Monitoring ports (docker-compose) ────────────────────────────────────────
PROMETHEUS_PORT=9090
GRAFANA_PORT=3000

# Grafana admin password — change before exposing to any network
GRAFANA_ADMIN_PASSWORD=proedge
