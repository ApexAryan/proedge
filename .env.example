# Database
DATABASE_URL=postgresql+asyncpg://proedge:proedge@localhost:5432/proedge
DATABASE_URL_SYNC=postgresql://proedge:proedge@localhost:5432/proedge

# API
API_HOST=0.0.0.0
API_PORT=8000
API_WORKERS=4
SECRET_KEY=change-me-in-production

# Sports Data APIs
SPORTRADAR_API_KEY=your_key_here
ESPN_API_BASE_URL=https://site.api.espn.com/apis/site/v2/sports

# Azure ML
AZURE_SUBSCRIPTION_ID=your_subscription_id
AZURE_RESOURCE_GROUP=proedge-rg
AZURE_ML_WORKSPACE=proedge-ws
AZURE_TENANT_ID=your_tenant_id
AZURE_CLIENT_ID=your_client_id
AZURE_CLIENT_SECRET=your_client_secret

# Model Registry
MODEL_REGISTRY_PATH=/app/models
ACTIVE_MODEL_VERSION=latest

# Drift Detection
DRIFT_PSI_THRESHOLD=0.25
DRIFT_CHECK_INTERVAL_HOURS=24

# Monitoring
PROMETHEUS_PORT=9090
GRAFANA_PORT=3000
