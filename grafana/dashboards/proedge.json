{
  "title": "ProEdge Analytics — Model Performance",
  "uid": "proedge-main",
  "schemaVersion": 38,
  "version": 3,
  "refresh": "30s",
  "time": { "from": "now-3h", "to": "now" },
  "templating": {
    "list": [
      {
        "name": "sport",
        "type": "custom",
        "label": "Sport",
        "options": [
          { "text": "NBA", "value": "nba", "selected": true },
          { "text": "NFL", "value": "nfl", "selected": false },
          { "text": "MLB", "value": "mlb", "selected": false }
        ],
        "current": { "text": "NBA", "value": "nba" },
        "hide": 0,
        "includeAll": false,
        "multi": false,
        "query": "nba,nfl,mlb"
      }
    ]
  },
  "panels": [
    {
      "id": 1,
      "title": "Live Model Accuracy",
      "type": "stat",
      "datasource": { "type": "prometheus", "uid": "afk5dwgbz82yoe" },
      "gridPos": { "x": 0, "y": 0, "w": 6, "h": 4 },
      "targets": [{
        "datasource": { "type": "prometheus", "uid": "afk5dwgbz82yoe" },
        "expr": "max by (sport) (proedge_model_accuracy{sport=\"$sport\"})",
        "legendFormat": "Accuracy",
        "instant": true
      }],
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"] },
        "colorMode": "background",
        "graphMode": "none",
        "textMode": "value"
      },
      "fieldConfig": {
        "defaults": {
          "unit": "percentunit",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "red", "value": null },
              { "color": "yellow", "value": 0.55 },
              { "color": "green", "value": 0.65 }
            ]
          },
          "mappings": []
        }
      }
    },
    {
      "id": 2,
      "title": "Log Loss",
      "type": "stat",
      "datasource": { "type": "prometheus", "uid": "afk5dwgbz82yoe" },
      "gridPos": { "x": 6, "y": 0, "w": 6, "h": 4 },
      "targets": [{
        "datasource": { "type": "prometheus", "uid": "afk5dwgbz82yoe" },
        "expr": "max by (sport) (proedge_model_log_loss{sport=\"$sport\"})",
        "legendFormat": "Log Loss",
        "instant": true
      }],
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"] },
        "colorMode": "background",
        "graphMode": "none",
        "textMode": "value"
      },
      "fieldConfig": {
        "defaults": {
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 0.65 },
              { "color": "red", "value": 0.70 }
            ]
          },
          "mappings": []
        }
      }
    },
    {
      "id": 3,
      "title": "Brier Score",
      "type": "stat",
      "datasource": { "type": "prometheus", "uid": "afk5dwgbz82yoe" },
      "gridPos": { "x": 12, "y": 0, "w": 6, "h": 4 },
      "targets": [{
        "datasource": { "type": "prometheus", "uid": "afk5dwgbz82yoe" },
        "expr": "max by (sport) (proedge_model_brier_score{sport=\"$sport\"})",
        "legendFormat": "Brier Score",
        "instant": true
      }],
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"] },
        "colorMode": "background",
        "graphMode": "none",
        "textMode": "value"
      },
      "fieldConfig": {
        "defaults": {
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 0.25 },
              { "color": "red", "value": 0.30 }
            ]
          },
          "mappings": []
        }
      }
    },
    {
      "id": 12,
      "title": "Total Predictions",
      "type": "stat",
      "datasource": { "type": "prometheus", "uid": "afk5dwgbz82yoe" },
      "gridPos": { "x": 18, "y": 0, "w": 6, "h": 4 },
      "targets": [{
        "datasource": { "type": "prometheus", "uid": "afk5dwgbz82yoe" },
        "expr": "sum(proedge_predictions_total{sport=\"$sport\"}) or vector(0)",
        "legendFormat": "Predictions",
        "instant": true
      }],
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"] },
        "colorMode": "value",
        "graphMode": "none",
        "textMode": "value"
      },
      "fieldConfig": {
        "defaults": { "unit": "short", "mappings": [] }
      }
    },
    {
      "id": 4,
      "title": "API Request Rate",
      "type": "timeseries",
      "datasource": { "type": "prometheus", "uid": "afk5dwgbz82yoe" },
      "gridPos": { "x": 0, "y": 4, "w": 12, "h": 8 },
      "targets": [{
        "datasource": { "type": "prometheus", "uid": "afk5dwgbz82yoe" },
        "expr": "rate(proedge_api_requests_total[5m])",
        "legendFormat": "{{method}} {{endpoint}} {{status_code}}"
      }],
      "options": { "tooltip": { "mode": "multi" } },
      "fieldConfig": {
        "defaults": { "unit": "reqps" }
      }
    },
    {
      "id": 5,
      "title": "API P95 Latency (ms)",
      "type": "timeseries",
      "datasource": { "type": "prometheus", "uid": "afk5dwgbz82yoe" },
      "gridPos": { "x": 12, "y": 4, "w": 12, "h": 8 },
      "targets": [{
        "datasource": { "type": "prometheus", "uid": "afk5dwgbz82yoe" },
        "expr": "histogram_quantile(0.95, rate(proedge_api_request_duration_seconds_bucket[5m])) * 1000",
        "legendFormat": "p95 {{endpoint}}"
      }],
      "fieldConfig": {
        "defaults": {
          "unit": "ms",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 150 },
              { "color": "red", "value": 200 }
            ]
          }
        }
      }
    },
    {
      "id": 6,
      "title": "Prediction Confidence Percentiles",
      "type": "stat",
      "datasource": { "type": "prometheus", "uid": "afk5dwgbz82yoe" },
      "gridPos": { "x": 0, "y": 12, "w": 12, "h": 8 },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "afk5dwgbz82yoe" },
          "expr": "histogram_quantile(0.50, sum by (le) (proedge_prediction_confidence_bucket{sport=\"$sport\"}))",
          "legendFormat": "p50",
          "instant": true
        },
        {
          "datasource": { "type": "prometheus", "uid": "afk5dwgbz82yoe" },
          "expr": "histogram_quantile(0.75, sum by (le) (proedge_prediction_confidence_bucket{sport=\"$sport\"}))",
          "legendFormat": "p75",
          "instant": true
        },
        {
          "datasource": { "type": "prometheus", "uid": "afk5dwgbz82yoe" },
          "expr": "histogram_quantile(0.90, sum by (le) (proedge_prediction_confidence_bucket{sport=\"$sport\"}))",
          "legendFormat": "p90",
          "instant": true
        }
      ],
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"] },
        "colorMode": "value",
        "graphMode": "none",
        "textMode": "value_and_name",
        "orientation": "horizontal"
      },
      "fieldConfig": {
        "defaults": { "unit": "percentunit", "min": 0, "max": 1, "mappings": [] }
      }
    },
    {
      "id": 7,
      "title": "Over Probability Percentiles",
      "type": "stat",
      "datasource": { "type": "prometheus", "uid": "afk5dwgbz82yoe" },
      "gridPos": { "x": 12, "y": 12, "w": 12, "h": 8 },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "afk5dwgbz82yoe" },
          "expr": "histogram_quantile(0.25, sum by (le) (proedge_prediction_prob_over_bucket{sport=\"$sport\"}))",
          "legendFormat": "p25",
          "instant": true
        },
        {
          "datasource": { "type": "prometheus", "uid": "afk5dwgbz82yoe" },
          "expr": "histogram_quantile(0.50, sum by (le) (proedge_prediction_prob_over_bucket{sport=\"$sport\"}))",
          "legendFormat": "p50",
          "instant": true
        },
        {
          "datasource": { "type": "prometheus", "uid": "afk5dwgbz82yoe" },
          "expr": "histogram_quantile(0.75, sum by (le) (proedge_prediction_prob_over_bucket{sport=\"$sport\"}))",
          "legendFormat": "p75",
          "instant": true
        }
      ],
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"] },
        "colorMode": "value",
        "graphMode": "none",
        "textMode": "value_and_name",
        "orientation": "horizontal"
      },
      "fieldConfig": {
        "defaults": { "unit": "percentunit", "min": 0, "max": 1, "mappings": [] }
      }
    },
    {
      "id": 8,
      "title": "Prediction Direction Split",
      "type": "piechart",
      "datasource": { "type": "prometheus", "uid": "afk5dwgbz82yoe" },
      "gridPos": { "x": 0, "y": 20, "w": 8, "h": 8 },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "afk5dwgbz82yoe" },
          "expr": "sum(proedge_predictions_total{sport=\"$sport\", direction=\"over\"}) or vector(0)",
          "legendFormat": "Over",
          "instant": true
        },
        {
          "datasource": { "type": "prometheus", "uid": "afk5dwgbz82yoe" },
          "expr": "sum(proedge_predictions_total{sport=\"$sport\", direction=\"under\"}) or vector(0)",
          "legendFormat": "Under",
          "instant": true
        }
      ],
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"] },
        "pieType": "pie",
        "displayLabels": ["name", "percent"]
      }
    },
    {
      "id": 9,
      "title": "Drift PSI — Top Features",
      "type": "bargauge",
      "datasource": { "type": "prometheus", "uid": "afk5dwgbz82yoe" },
      "gridPos": { "x": 8, "y": 20, "w": 16, "h": 8 },
      "targets": [{
        "datasource": { "type": "prometheus", "uid": "afk5dwgbz82yoe" },
        "expr": "proedge_drift_psi{sport=\"$sport\"}",
        "legendFormat": "{{feature}}",
        "instant": true
      }],
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"] },
        "orientation": "horizontal",
        "displayMode": "gradient"
      },
      "fieldConfig": {
        "defaults": {
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 0.10 },
              { "color": "red", "value": 0.25 }
            ]
          }
        }
      }
    },
    {
      "id": 10,
      "title": "Model Retrains",
      "type": "timeseries",
      "datasource": { "type": "prometheus", "uid": "afk5dwgbz82yoe" },
      "gridPos": { "x": 0, "y": 28, "w": 12, "h": 6 },
      "targets": [{
        "datasource": { "type": "prometheus", "uid": "afk5dwgbz82yoe" },
        "expr": "increase(proedge_model_retrains_total[1d])",
        "legendFormat": "{{sport}} ({{trigger_reason}})"
      }],
      "fieldConfig": {
        "defaults": { "unit": "short" }
      }
    },
    {
      "id": 11,
      "title": "Total Predictions (24h)",
      "type": "stat",
      "datasource": { "type": "prometheus", "uid": "afk5dwgbz82yoe" },
      "gridPos": { "x": 12, "y": 28, "w": 6, "h": 6 },
      "targets": [{
        "datasource": { "type": "prometheus", "uid": "afk5dwgbz82yoe" },
        "expr": "sum(increase(proedge_predictions_total[24h])) or vector(0)",
        "legendFormat": "Last 24h",
        "instant": true
      }],
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"] },
        "colorMode": "value",
        "graphMode": "area",
        "textMode": "value"
      },
      "fieldConfig": {
        "defaults": { "unit": "short", "mappings": [] }
      }
    },
    {
      "id": 13,
      "title": "Predictions by Sport (All Time)",
      "type": "bargauge",
      "datasource": { "type": "prometheus", "uid": "afk5dwgbz82yoe" },
      "gridPos": { "x": 18, "y": 28, "w": 6, "h": 6 },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "afk5dwgbz82yoe" },
          "expr": "sum(proedge_predictions_total{sport=\"nba\"}) or vector(0)",
          "legendFormat": "NBA",
          "instant": true
        },
        {
          "datasource": { "type": "prometheus", "uid": "afk5dwgbz82yoe" },
          "expr": "sum(proedge_predictions_total{sport=\"nfl\"}) or vector(0)",
          "legendFormat": "NFL",
          "instant": true
        },
        {
          "datasource": { "type": "prometheus", "uid": "afk5dwgbz82yoe" },
          "expr": "sum(proedge_predictions_total{sport=\"mlb\"}) or vector(0)",
          "legendFormat": "MLB",
          "instant": true
        }
      ],
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"] },
        "orientation": "horizontal",
        "displayMode": "basic"
      },
      "fieldConfig": {
        "defaults": { "unit": "short" }
      }
    }
  ]
}
